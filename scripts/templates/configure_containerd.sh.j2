#!/usr/bin/env bash
set -euo pipefail

PAUSE_IMAGE="{{ pause_image }}"
CONFIG="/etc/containerd/config.toml"
CERTS_DIR="/etc/containerd/certs.d"

IMAGES='^\[plugins\."io\.containerd\.cri\.v1\.images"\]$'
IMAGES_ANY='^\[plugins\."io\.containerd\.cri\.v1\.images"'
IMAGES_REG='^\[plugins\."io\.containerd\.cri\.v1\.images"\.registry\]$'
GRPC='^\[plugins\."io\.containerd\.grpc\.v1\.cri"\]$'
GRPC_REG='^\[plugins\."io\.containerd\.grpc\.v1\.cri"\.registry\]$'

mkdir -p /etc/containerd
containerd config default > "${CONFIG}"
sed -ri 's#(SystemdCgroup = )false#\1true#g' "${CONFIG}"

# sandbox_image
# containerd 2.x often has only [plugins."io.containerd.cri.v1.images".registry]
# which implicitly creates the parent table — appending [..images] again duplicates it.
if grep -qE '^\s*sandbox_image\s*=' "${CONFIG}"; then
  sed -ri "0,/^\s*sandbox_image\s*=.*$/s//  sandbox_image = \"${PAUSE_IMAGE}\"/" "${CONFIG}"
elif grep -qE "${IMAGES}" "${CONFIG}"; then
  awk -v img="${PAUSE_IMAGE}" '
    /^\[plugins\."io\.containerd\.cri\.v1\.images"\]$/ {
      print
      print "  sandbox_image = \"" img "\""
      next
    }
    { print }
  ' "${CONFIG}" > "${CONFIG}.tmp" && mv "${CONFIG}.tmp" "${CONFIG}"
elif grep -qE "${IMAGES_ANY}" "${CONFIG}"; then
  awk -v img="${PAUSE_IMAGE}" '
    /^\[plugins\."io\.containerd\.cri\.v1\.images"/ && !done {
      print "[plugins.\"io.containerd.cri.v1.images\"]"
      print "  sandbox_image = \"" img "\""
      print ""
      done = 1
    }
    { print }
  ' "${CONFIG}" > "${CONFIG}.tmp" && mv "${CONFIG}.tmp" "${CONFIG}"
elif grep -qE "${GRPC}" "${CONFIG}"; then
  awk -v img="${PAUSE_IMAGE}" '
    /^\[plugins\."io\.containerd\.grpc\.v1\.cri"\]$/ {
      print
      print "  sandbox_image = \"" img "\""
      next
    }
    { print }
  ' "${CONFIG}" > "${CONFIG}.tmp" && mv "${CONFIG}.tmp" "${CONFIG}"
else
  cat >>"${CONFIG}" <<EOF

[plugins."io.containerd.cri.v1.images"]
  sandbox_image = "${PAUSE_IMAGE}"
EOF
fi

# registry mirrors path
if grep -qE '^\s*config_path\s*=' "${CONFIG}"; then
  sed -ri "s#^\s*config_path\s*=.*#  config_path = \"${CERTS_DIR}\"#g" "${CONFIG}"
elif grep -qE "${IMAGES_REG}" "${CONFIG}"; then
  awk -v p="${CERTS_DIR}" '
    /^\[plugins\."io\.containerd\.cri\.v1\.images"\.registry\]$/ {
      print
      print "  config_path = \"" p "\""
      next
    }
    { print }
  ' "${CONFIG}" > "${CONFIG}.tmp" && mv "${CONFIG}.tmp" "${CONFIG}"
elif grep -qE "${GRPC_REG}" "${CONFIG}"; then
  awk -v p="${CERTS_DIR}" '
    /^\[plugins\."io\.containerd\.grpc\.v1\.cri"\.registry\]$/ {
      print
      print "  config_path = \"" p "\""
      next
    }
    { print }
  ' "${CONFIG}" > "${CONFIG}.tmp" && mv "${CONFIG}.tmp" "${CONFIG}"
elif grep -qE "${IMAGES}" "${CONFIG}" && ! grep -qE "${IMAGES_REG}" "${CONFIG}"; then
  cat >>"${CONFIG}" <<EOF

[plugins."io.containerd.cri.v1.images".registry]
  config_path = "${CERTS_DIR}"
EOF
elif grep -qE "${GRPC}" "${CONFIG}" && ! grep -qE "${GRPC_REG}" "${CONFIG}"; then
  cat >>"${CONFIG}" <<EOF

[plugins."io.containerd.grpc.v1.cri".registry]
  config_path = "${CERTS_DIR}"
EOF
fi

mkdir -p /etc/containerd/certs.d/docker.io
cat >/etc/containerd/certs.d/docker.io/hosts.toml <<'EOF'
server = "https://registry-1.docker.io"

[host."{{ docker_io_mirror }}"]
  capabilities = ["pull", "resolve"]

[host."https://registry-1.docker.io"]
  capabilities = ["pull", "resolve"]
EOF

mkdir -p /etc/containerd/certs.d/quay.io
cat >/etc/containerd/certs.d/quay.io/hosts.toml <<'EOF'
server = "https://quay.io"

[host."{{ quay_io_mirror }}"]
  capabilities = ["pull", "resolve"]

[host."https://quay.io"]
  capabilities = ["pull", "resolve"]
EOF

mkdir -p /etc/containerd/certs.d/ghcr.io
cat >/etc/containerd/certs.d/ghcr.io/hosts.toml <<'EOF'
server = "https://ghcr.io"

[host."{{ ghcr_io_mirror }}"]
  capabilities = ["pull", "resolve"]

[host."https://ghcr.io"]
  capabilities = ["pull", "resolve"]
EOF

mkdir -p /etc/containerd/certs.d/registry.k8s.io
{% if k8s_registry_mirror | default('') | length > 0 %}
cat >/etc/containerd/certs.d/registry.k8s.io/hosts.toml <<'EOF'
server = "https://registry.k8s.io"

[host."{{ k8s_registry_mirror }}"]
  capabilities = ["pull", "resolve"]

[host."https://registry.k8s.io"]
  capabilities = ["pull", "resolve"]
EOF
{% else %}
cat >/etc/containerd/certs.d/registry.k8s.io/hosts.toml <<'EOF'
server = "https://registry.k8s.io"

[host."https://registry.k8s.io"]
  capabilities = ["pull", "resolve"]
EOF
{% endif %}

cat >/etc/crictl.yaml <<'EOF'
runtime-endpoint: unix:///run/containerd/containerd.sock
image-endpoint: unix:///run/containerd/containerd.sock
timeout: 0
EOF

mkdir -p /var/lib/containerd

if ! containerd --config "${CONFIG}" config dump >/dev/null 2>&1; then
  echo "containerd config validation failed:" >&2
  containerd --config "${CONFIG}" config dump >&2 || true
  exit 1
fi

systemctl daemon-reload
systemctl enable containerd
systemctl restart containerd
